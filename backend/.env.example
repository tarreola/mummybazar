# App
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False

# PostgreSQL — create a database called mommybazar
DATABASE_URL=postgresql://postgres:password@localhost:5432/mommybazar

# Twilio WhatsApp
# Get these at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number (replace with approved sender in production)

# MercadoPago
# Get these at: https://www.mercadopago.com.mx/developers/panel
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
MP_WEBHOOK_SECRET=

# Cloudinary
# Get these at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
